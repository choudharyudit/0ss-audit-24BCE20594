#!/bin/bash
# Script 3: Disk and Permission Auditor

DIRS=("/etc" "/var/log" "/home" "/usr/bin" "/tmp")

echo "Directory Audit Report"
echo "------------------------------------------"

for DIR in "${DIRS[@]}"; do
    if [ -d "$DIR" ]; then
        # Extract permissions, owner, and group
        PERMS=$(ls -ld "$DIR" | awk '{print $1, $3, $4}')
        SIZE=$(du -sh "$DIR" 2>/dev/null | cut -f1)
        echo "DIR: $DIR | Perms: $PERMS | Size: $SIZE"
    else
        echo "Warning: $DIR does not exist on this system."
    fi
done

# Check Git's system configuration directory
GIT_CONF="/etc/gitconfig"
if [ -f "$GIT_CONF" ] || [ -d "$GIT_CONF" ]; then
    echo "------------------------------------------"
    echo "Software Config found: $(ls -ld $GIT_CONF | awk '{print $1}')"
fi
