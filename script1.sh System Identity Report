# --- Variables ---
STUDENT_NAME="Udit choudhary"
SOFTWARE_CHOICE="Git"
KERNEL=$(uname -r)
USER_NAME=$(whoami)
UPTIME=$(uptime -p)
DISTRO=$(grep ^PRETTY_NAME /etc/os-release | cut -d'"' -f2)
CURRENT_DATE=$(date)

# --- Display ---
echo "=========================================="
echo "         Open Source Audit                "
echo "=========================================="
echo "Student  : $STUDENT_NAME"
echo "Software : $SOFTWARE_CHOICE"
echo "------------------------------------------"
echo "OS Distro: $DISTRO"
echo "Kernel   : $KERNEL"
echo "User     : $USER_NAME ($HOME)"
echo "Uptime   : $UPTIME"
echo "Date/Time: $CURRENT_DATE"
echo "------------------------------------------"
echo "Note: This OS is powered by Open Source (GPL License)."
echo "=========================================="
